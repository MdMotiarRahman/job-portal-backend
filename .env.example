# ========================================
# JOBLAND BACKEND - ENVIRONMENT SETUP
# ========================================

# ===== DATABASE =====
MONGODB_URI=mongodb://localhost:27017/jobland
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/jobland

# ===== JWT =====
JWT_SECRET=your_secret_key_here_change_this_in_production

# ===== CLOUDINARY (Optional - For image uploads) =====
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== PORT =====
PORT=5000

# ===== EMAIL CONFIGURATION =====
# Choose provider: mailtrap, gmail, or console

# Option 1: MAILTRAP (Recommended for Testing - FREE)
# Sign up at https://mailtrap.io (no credit card required)
EMAIL_PROVIDER=mailtrap
MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_user_id
MAILTRAP_PASS=your_mailtrap_password
EMAIL_FROM=noreply@jobland.com

# Option 2: GMAIL (For Production)
# Generate app password: https://myaccount.google.com/apppasswords
# EMAIL_PROVIDER=gmail
# GMAIL_USER=your-email@gmail.com
# GMAIL_PASS=your-app-specific-password (16 characters)
# EMAIL_FROM=your-email@gmail.com

# Option 3: CONSOLE (Development/Testing Only)
# EMAIL_PROVIDER=console
# EMAIL_FROM=noreply@jobland.com

# ========================================
# INSTRUCTIONS
# ========================================
#
# STEP 1: Choose your email provider above
#
# STEP 2: For MAILTRAP (Recommended for Educational Projects):
#   1. Go to https://mailtrap.io
#   2. Click "Sign Up" (no credit card needed!)
#   3. Verify your email
#   4. Create a free account
#   5. Create an "Inbox" (name it "JobLand Dev")
#   6. Go to Settings → Integrations
#   7. Select "Nodemailer"
#   8. Copy the credentials and paste them above
#
# STEP 3: For GMAIL (For Production):
#   1. Go to https://myaccount.google.com/security
#   2. Enable "2-Step Verification" if not already done
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Select "Mail" and "Windows Computer"
#   5. Copy the 16-character password
#   6. Uncomment GMAIL options above and paste credentials
#
# STEP 4: For CONSOLE (Testing Only):
#   Set EMAIL_PROVIDER=console
#   Emails will be logged to console instead of sent
#
# STEP 5: Restart your server
#   npm run dev
#
# STEP 6: Check the console output
#   You should see: ✅ Email service ready (Provider: MAILTRAP)
#                  ✅ Reminder schedules initialized
#
# ========================================
